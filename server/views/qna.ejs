<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Assessment Portal</title>
    <style>
        :root {
            --bg-color: #0d1117;
            --surface-color: #161b22;
            --border-color: #30363d;
            --text-primary: #c9d1d9;
            --text-secondary: #8b949e;
            --accent-color: #58a6ff;
            --accent-hover: #3182ce;
            --card-hover: #21262d;
            --success-color: #238636;
            --warning-color: #d29922;
        }

        * {
            box-sizing: border-box; margin: 0; padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; padding: 1rem;
        }

        .quiz-container {
            background-color: var(--surface-color);
            border: 1px solid var(--border-color);
            border-radius: 12px; padding: 2rem;
            width: 100%; max-width: 650px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
            display: flex; flex-direction: column;
            min-height: 400px;
        }

        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 1.5rem; padding-bottom: 1rem;
            border-bottom: 1px solid var(--border-color);
        }

        .test-meta {
            display: flex; flex-direction: column; gap: 4px;
        }

        .test-title { font-size: 1.1rem; font-weight: 600; color: var(--accent-color); }
        .progress-text { font-size: 0.85rem; color: var(--text-secondary); }

        .timer {
            font-family: monospace; font-size: 1.2rem;
            color: var(--warning-color); font-weight: bold;
            background: rgba(210, 153, 34, 0.1);
            padding: 6px 12px; border-radius: 6px; border: 1px solid var(--warning-color);
        }

        h2#question-text {
            font-size: 1.2rem; line-height: 1.5; margin-bottom: 1.5rem; font-weight: 500;
        }

        .options { display: flex; flex-direction: column; gap: 12px; flex-grow: 1; margin-bottom: 2rem; }

        .option-label {
            display: flex; align-items: center; padding: 1rem;
            background-color: var(--bg-color); border: 1px solid var(--border-color);
            border-radius: 8px; cursor: pointer; transition: all 0.2s ease-in-out;
        }

        .option-label:hover { background-color: var(--card-hover); border-color: var(--text-secondary); }

        .option-label input[type="radio"] {
            appearance: none; width: 20px; height: 20px;
            border: 2px solid var(--text-secondary); border-radius: 50%;
            margin-right: 15px; display: grid; place-content: center; transition: all 0.2s;
        }

        .option-label input[type="radio"]::before {
            content: ""; width: 10px; height: 10px; border-radius: 50%;
            background-color: var(--bg-color); transform: scale(0); transition: 120ms transform ease-in-out;
        }

        .option-label input[type="radio"]:checked {
            background-color: var(--accent-color); border-color: var(--accent-color);
        }

        .option-label input[type="radio"]:checked::before { transform: scale(1); }
        .option-label:has(input[type="radio"]:checked) {
            border-color: var(--accent-color); background-color: rgba(88, 166, 255, 0.05);
        }

        .footer-controls {
            display: flex; justify-content: space-between; gap: 1rem; margin-top: auto;
        }

        button {
            padding: 12px 24px; border-radius: 6px; font-size: 1rem; font-weight: 600;
            cursor: pointer; transition: background-color 0.2s; border: none;
        }

        .btn-outline {
            background-color: transparent; color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        .btn-outline:hover:not(:disabled) { background-color: var(--card-hover); }

        .btn-primary { background-color: var(--accent-color); color: #fff; }
        .btn-primary:hover:not(:disabled) { background-color: var(--accent-hover); }

        .btn-success { background-color: var(--success-color); color: #fff; display: none; }
        .btn-success:hover:not(:disabled) { background-color: #2ea043; }

        button:disabled {
            background-color: var(--bg-color); color: var(--text-secondary);
            border-color: var(--border-color); cursor: not-allowed; opacity: 0.5;
        }

        #loading-indicator { display: none; text-align: center; padding: 2rem 0; flex-grow: 1; }
        .spinner {
            width: 40px; height: 40px; border: 4px solid var(--border-color);
            border-top: 4px solid var(--accent-color); border-radius: 50%;
            animation: spin 1s linear infinite; margin: 0 auto 1rem auto;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* Results Screen */
        #results-screen { display: none; text-align: center; }
        .score-display { font-size: 3rem; font-weight: bold; color: var(--success-color); margin: 1rem 0; }
        .code-block { background: #000; color: #0f0; padding: 1rem; border-radius: 8px; text-align: left; overflow-x: auto; font-family: monospace; font-size: 0.85rem; margin-top: 1rem;}
    </style>
</head>
<body>

    <div class="quiz-container">
        <div id="quiz-ui">
            <div class="header">
                <div class="test-meta">
                    <span id="test-title" class="test-title">Loading...</span>
                    <span id="progress-text" class="progress-text"></span>
                </div>
                <div id="timer" class="timer">00:00</div>
            </div>
            
            <div id="loading-indicator">
                <div class="spinner"></div>
                <p style="color: var(--text-secondary);">Syncing telemetry...</p>
            </div>

            <div id="question-content">
                <h2 id="question-text">Initializing parameters...</h2>
                <div id="options-container" class="options"></div>
            </div>

            <div class="footer-controls">
                <button id="prev-btn" class="btn-outline" disabled>Previous</button>
                <button id="next-btn" class="btn-primary">Next</button>
                <button id="submit-btn" class="btn-success">Submit Test</button>
            </div>
        </div>

        <div id="results-screen">
            <h2>Assessment Complete</h2>
            <div id="final-score" class="score-display"></div>
            <p id="time-taken-display" style="color: var(--text-secondary);"></p>
            <p style="margin-top: 1.5rem; text-align: left;">Generated JSON Payload (Sent to API):</p>
            <div id="json-output" class="code-block"></div>
        </div>
    </div>

    <script src="/js/qna.js"></script>
</body>
</html>